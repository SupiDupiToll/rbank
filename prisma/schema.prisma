generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(cuid())
  stackUserId           String            @unique
  role                  Role              @default(CUSTOMER)
  createdAt             DateTime          @default(now())
  customerId            String            @unique
  displayName           String?
  paymentPinHash        String?           @map("payment_pin_hash")
  pinLockedUntil        DateTime?         @map("pin_locked_until")
  showDonationBoxesList Boolean           @default(false) @map("show_donation_boxes_list")
  balanceCents          Int               @default(0) @map("balance_cents")
  donationBoxes         DonationBox[]
  festgeld              FestgeldAccount[]
  paymentSessions       PaymentSession[]  @relation("CheckoutPayer")
  receivedPayments      PaymentSession[]  @relation("CheckoutRecipient")
  pinAttempts           PinAttempt[]
  transactions          Transaction[]
  loans                 Loan[]
}

model DonationBox {
  id              String           @id @default(cuid())
  userId          String
  name            String
  slug            String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  isActive        Boolean          @default(true) @map("is_active")
  paymentSessions PaymentSession[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Int
  currency         TransactionCurrency @default(EUR)
  description      String
  date             DateTime
  createdAt        DateTime          @default(now())
  source           TransactionSource @default(ADMIN)
  transferId       String?
  paymentSessionId String?           @map("payment_session_id")
  paymentSession   PaymentSession?   @relation(fields: [paymentSessionId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([transferId])
  @@index([paymentSessionId])
}

model FestgeldAccount {
  id                  String         @id @default(cuid())
  userId              String
  label               String
  amount              Int
  interestRate        Float
  startDate           DateTime
  endDate             DateTime
  createdAt           DateTime       @default(now())
  status              FestgeldStatus @default(ACTIVE)
  interestCreditedAt  DateTime?
  payoutDate          DateTime?
  payoutTransactionId String?
  lockedTransactionId String?
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endDate])
  @@index([status, endDate])
}

model Merchant {
  id                  String           @id @default(cuid())
  name                String
  merchantId          String           @unique @map("merchant_id")
  merchantSecretHash  String           @map("merchant_secret_hash")
  allowedRedirectUrls String[]         @map("allowed_redirect_urls")
  webhookUrl          String?          @map("webhook_url")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  webhookSecretEnc    String?          @map("webhook_secret_enc")
  webhookSecretHash   String?          @map("webhook_secret_hash")
  paymentSessions     PaymentSession[]

  @@index([isActive, createdAt])
}

model PaymentSession {
  id                     String               @id @default(cuid())
  merchantDbId           String               @map("merchant_db_id")
  amount                 Int
  currency               String               @default("EUR")
  description            String
  redirectUrl            String               @map("redirect_url")
  cancelUrl              String               @map("cancel_url")
  metadataJson           Json?                @map("metadata_json")
  status                 PaymentSessionStatus @default(PENDING)
  token                  String               @unique
  userId                 String?
  recipientUserId        String?              @map("recipient_user_id")
  donationBoxId          String?              @map("donation_box_id")
  paidAt                 DateTime?            @map("paid_at")
  completedTransactionId String?              @map("completed_transaction_id")
  refundTransactionId    String?              @map("refund_transaction_id")
  refundedAt             DateTime?            @map("refunded_at")
  createdAt              DateTime             @default(now()) @map("created_at")
  expiresAt              DateTime             @map("expires_at")
  donationBox            DonationBox?         @relation(fields: [donationBoxId], references: [id])
  merchant               Merchant             @relation(fields: [merchantDbId], references: [id], onDelete: Cascade)
  recipientUser          User?                @relation("CheckoutRecipient", fields: [recipientUserId], references: [id])
  user                   User?                @relation("CheckoutPayer", fields: [userId], references: [id])
  transactions           Transaction[]

  @@index([merchantDbId, createdAt])
  @@index([status, expiresAt])
  @@index([userId, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([donationBoxId, createdAt])
}

model PinAttempt {
  id        String   @id @default(cuid())
  userId    String
  ip        String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ip, createdAt])
}

model LoanProduct {
  id             String   @id @default(cuid())
  name           String
  description    String
  minAmount      Int      @map("min_amount")
  maxAmount      Int      @map("max_amount")
  minTermMonths  Int      @map("min_term_months")
  maxTermMonths  Int      @map("max_term_months")
  interestRate   Float    @map("interest_rate")
  oneTimeFeeCents Int?    @map("one_time_fee_cents")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  loans          Loan[]

  @@index([isActive])
}

model Loan {
  id                     String        @id @default(cuid())
  userId                 String        @map("user_id")
  loanProductId          String?       @map("loan_product_id")
  amount                 Int
  interestRate           Float         @map("interest_rate")
  termMonths             Int           @map("term_months")
  monthlyPayment         Int           @map("monthly_payment")
  totalInterest          Int           @map("total_interest")
  totalRepayment         Int           @map("total_repayment")
  remainingAmount        Int           @map("remaining_amount")
  oneTimeFeeCents        Int?          @map("one_time_fee_cents")
  oneTimeFeePaid         Boolean       @default(false) @map("one_time_fee_paid")
  status                 LoanStatus    @default(PENDING)
  purpose                String?
  approvedAt             DateTime?     @map("approved_at")
  approvedByUserId       String?       @map("approved_by_user_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  disbursementTxId       String?       @map("disbursement_tx_id")
  paidOffAt              DateTime?     @map("paid_off_at")
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanProduct            LoanProduct?  @relation(fields: [loanProductId], references: [id])
  payments               LoanPayment[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model LoanPayment {
  id                String        @id @default(cuid())
  loanId            String        @map("loan_id")
  installmentNumber Int           @map("installment_number")
  scheduledDate     DateTime      @map("scheduled_date")
  paidAt            DateTime?     @map("paid_at")
  amount            Int
  principalPortion  Int           @map("principal_portion")
  interestPortion   Int           @map("interest_portion")
  remainingBalance  Int           @map("remaining_balance")
  status            PaymentStatus @default(SCHEDULED)
  transactionId     String?       @map("transaction_id")
  loan              Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, installmentNumber])
  @@index([loanId, status])
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TransactionType {
  INCOMING
  OUTGOING
}

enum TransactionCurrency {
  EUR
  AIR
}

enum TransactionSource {
  ADMIN
  TRANSFER
  CHECKOUT
  DONATION
  REFUND
  OVERDRAFT_INTEREST
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  SCHEDULED
  PAID
  SKIPPED
  LATE
}

enum FestgeldStatus {
  ACTIVE
  UNLOCKED
  PAID_OUT
}

enum PaymentSessionStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
}
