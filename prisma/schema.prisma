generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  stackUserId     String            @unique
  role            Role              @default(CUSTOMER)
  createdAt       DateTime          @default(now())
  customerId      String            @unique
  displayName     String?
  paymentPinHash  String?           @map("payment_pin_hash")
  pinLockedUntil  DateTime?         @map("pin_locked_until")
  festgeld        FestgeldAccount[]
  paymentSessions PaymentSession[]
  pinAttempts     PinAttempt[]
  transactions    Transaction[]
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Int
  currency         TransactionCurrency @default(EUR)
  description      String
  date             DateTime
  createdAt        DateTime          @default(now())
  source           TransactionSource @default(ADMIN)
  transferId       String?
  paymentSessionId String?           @map("payment_session_id")
  paymentSession   PaymentSession?   @relation(fields: [paymentSessionId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([transferId])
  @@index([paymentSessionId])
}

model FestgeldAccount {
  id                  String         @id @default(cuid())
  userId              String
  label               String
  amount              Int
  interestRate        Float
  startDate           DateTime
  endDate             DateTime
  createdAt           DateTime       @default(now())
  status              FestgeldStatus @default(ACTIVE)
  interestCreditedAt  DateTime?
  payoutDate          DateTime?
  payoutTransactionId String?
  lockedTransactionId String?
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endDate])
  @@index([status, endDate])
}

model Merchant {
  id                  String           @id @default(cuid())
  name                String
  merchantId          String           @unique @map("merchant_id")
  merchantSecretHash  String           @map("merchant_secret_hash")
  allowedRedirectUrls String[]         @map("allowed_redirect_urls")
  webhookUrl          String?          @map("webhook_url")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  webhookSecretEnc    String?          @map("webhook_secret_enc")
  webhookSecretHash   String?          @map("webhook_secret_hash")
  paymentSessions     PaymentSession[]

  @@index([isActive, createdAt])
}

model PaymentSession {
  id                     String               @id @default(cuid())
  merchantDbId           String               @map("merchant_db_id")
  amount                 Int
  currency               String               @default("EUR")
  description            String
  redirectUrl            String               @map("redirect_url")
  cancelUrl              String               @map("cancel_url")
  metadataJson           Json?                @map("metadata_json")
  status                 PaymentSessionStatus @default(PENDING)
  token                  String               @unique
  userId                 String?
  paidAt                 DateTime?            @map("paid_at")
  completedTransactionId String?              @map("completed_transaction_id")
  refundTransactionId    String?              @map("refund_transaction_id")
  refundedAt             DateTime?            @map("refunded_at")
  createdAt              DateTime             @default(now()) @map("created_at")
  expiresAt              DateTime             @map("expires_at")
  merchant               Merchant             @relation(fields: [merchantDbId], references: [id], onDelete: Cascade)
  user                   User?                @relation(fields: [userId], references: [id])
  transactions           Transaction[]

  @@index([merchantDbId, createdAt])
  @@index([status, expiresAt])
  @@index([userId, createdAt])
}

model PinAttempt {
  id        String   @id @default(cuid())
  userId    String
  ip        String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ip, createdAt])
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TransactionType {
  INCOMING
  OUTGOING
}

enum TransactionCurrency {
  EUR
  AIR
}

enum TransactionSource {
  ADMIN
  TRANSFER
  CHECKOUT
  REFUND
}

enum FestgeldStatus {
  ACTIVE
  UNLOCKED
  PAID_OUT
}

enum PaymentSessionStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
}
